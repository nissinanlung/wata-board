# CDN Configuration for Production
# Copy this file to .env.production and update with your CDN settings

# CDN Base URL
CDN_BASE_URL=https://cdn.wata-board.com

# CDN Provider Configuration
CDN_PROVIDER=cloudflare
CDN_ZONE_ID=your_cloudflare_zone_id
CDN_API_TOKEN=your_cloudflare_api_token

# Asset Optimization
CDN_CACHE_TTL=31536000
CDN_BROWSER_CACHE_TTL=31536000
CDN_EDGE_CACHE_TTL=86400

# Compression Settings
CDN_ENABLE_GZIP=true
CDN_ENABLE_BROTLI=true
CDN_ENABLE_IMAGE_OPTIMIZATION=true

# Security Headers
CDN_ENABLE_HSTS=true
CDN_ENABLE_CSP=true
CDN_ENABLE_XSS_PROTECTION=true

# Fallback Configuration
CDN_FALLBACK_URL=https://app.wata-board.com
CDN_HEALTH_CHECK_ENABLED=true
CDN_HEALTH_CHECK_INTERVAL=300
